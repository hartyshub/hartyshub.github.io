---
import { getCollection } from 'astro:content';
import NewsCard from '@components/NewsCard.astro';
import Pagination from '@components/Pagination.astro';
import PageLayout from '@layouts/PageLayout.astro';
import { compareByDateDesc } from '@lib/site';

const PAGE_SIZE = 12;
const articles = (await getCollection('news')).sort(compareByDateDesc);
const [featuredArticle, ...archiveArticles] = articles;
const pagedArticles = archiveArticles.slice(0, PAGE_SIZE);
const totalPages = Math.max(1, Math.ceil(archiveArticles.length / PAGE_SIZE));
---

<PageLayout
  title="News"
  summary="An anonymized editorial stream with featured stories, applied research updates, and student activity."
  eyebrow="Editorial"
  contentWidth="wide"
>
  {featuredArticle && (
    <section class="section-block">
      <p class="eyebrow">Featured story</p>
      <article class="card">
        <div>
          <p class="kicker">{featuredArticle.data.category}</p>
          <h2>{featuredArticle.data.title}</h2>
          <p>{featuredArticle.data.summary}</p>
        </div>
        <a class="button-text" href={`/news/${featuredArticle.id}`}>Read featured story</a>
      </article>
    </section>
  )}

  <section class="section-block">
    <div class="archive-heading">
      <p class="eyebrow">Latest stories</p>
      <p class="archive-count">
        Showing {pagedArticles.length} of {archiveArticles.length} archive stories
      </p>
    </div>
    <div class="grid three">
      {pagedArticles.map((article) => <NewsCard article={article} />)}
    </div>
    <Pagination currentPage={1} totalPages={totalPages} basePath="/news" />
  </section>
</PageLayout>

<style>
  .section-block + .section-block {
    margin-top: 2rem;
  }

  h2 {
    margin: 0 0 0.6rem;
    font-size: 1.6rem;
    line-height: 1.15;
  }

  p:last-child {
    margin-bottom: 0;
  }

  .archive-heading {
    display: flex;
    flex-wrap: wrap;
    align-items: end;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .archive-heading .eyebrow,
  .archive-count {
    margin: 0;
  }

  .archive-count {
    color: var(--color-grey-700);
    font-weight: 700;
  }
</style>
