---
import type { CollectionEntry } from 'astro:content';
import { proofMetrics } from '@lib/site';
import ResponsiveImage from './ResponsiveImage.astro';

interface Props {
  featuredPrograms: CollectionEntry<'programs'>[];
}

const { featuredPrograms } = Astro.props;
---

<section class="section">
  <div class="container hero-grid">
    <div class="hero-copy">
      <span class="pill">Responsive university redesign mockup</span>
      <h1 class="headline">Harty College</h1>
      <p class="section-copy">
        AI-focused education, research, and innovation in Bangkok. Built as an anonymized
        content-driven concept site with Astro and Keystatic.
      </p>

      <div class="hero-actions">
        <a class="button" href="/programs">Explore Programs</a>
        <a class="button-secondary" href="/admissions">View Admissions</a>
      </div>
    </div>

    <div class="hero-panel">
      <div class="hero-showcase">
        <div>
          <p class="kicker">Featured pathways</p>
          <div class="eyeline"></div>
        </div>

        <div class="hero-program-list">
          {featuredPrograms.slice(0, 3).map((program) => (
            <article class="hero-program">
              <div>
                <p class="kicker">{program.data.degreeLevel}</p>
                <h2>{program.data.name}</h2>
              </div>
              <p>{program.data.overview}</p>
            </article>
          ))}
        </div>

        <ResponsiveImage aspect="wide" />
      </div>
    </div>
  </div>

  <div class="container stat-grid hero-stats">
    {proofMetrics.map((metric) => (
      <div class="stat card">
        <strong>{metric.value}</strong>
        <span>{metric.label}</span>
      </div>
    ))}
  </div>
</section>

<style>
  .hero-grid {
    display: grid;
    gap: 1.5rem;
  }

  .hero-copy {
    display: grid;
    gap: 1.25rem;
    align-content: center;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
  }

  .hero-showcase {
    display: grid;
    gap: 1rem;
    padding: 1.25rem;
  }

  .hero-program-list {
    display: grid;
    gap: 0.9rem;
  }

  .hero-program {
    display: grid;
    gap: 0.4rem;
    padding-bottom: 0.9rem;
    border-bottom: 1px solid rgba(31, 32, 35, 0.08);
  }

  .hero-program:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .hero-program h2 {
    margin: 0.15rem 0 0;
    font-size: 1.2rem;
    line-height: 1.2;
  }

  .hero-program p {
    margin: 0;
    color: var(--color-grey-700);
  }

  .hero-stats {
    margin-top: 1rem;
  }

  @media (min-width: 1024px) {
    .hero-grid {
      grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
      align-items: stretch;
    }
  }
</style>
