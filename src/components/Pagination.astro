---
interface Props {
  currentPage: number;
  totalPages: number;
  basePath: string;
}

const { currentPage, totalPages, basePath } = Astro.props;
const pageHref = (page: number) => (page === 1 ? basePath : `${basePath}/page/${page}`);
const pages = Array.from({ length: totalPages }, (_, index) => index + 1);
---

{
  totalPages > 1 && (
    <nav class="pagination" aria-label="News archive pagination">
      {currentPage > 1 ? (
        <a class="pagination-link pagination-step" href={pageHref(currentPage - 1)} rel="prev">
          Previous
        </a>
      ) : (
        <span class="pagination-link pagination-step disabled" aria-disabled="true">Previous</span>
      )}

      <div class="pagination-pages">
        {pages.map((page) => (
          <a
            class:list={['pagination-link', { active: page === currentPage }]}
            href={pageHref(page)}
            aria-current={page === currentPage ? 'page' : undefined}
            aria-label={`Page ${page}`}
          >
            {page}
          </a>
        ))}
      </div>

      {currentPage < totalPages ? (
        <a class="pagination-link pagination-step" href={pageHref(currentPage + 1)} rel="next">
          Next
        </a>
      ) : (
        <span class="pagination-link pagination-step disabled" aria-disabled="true">Next</span>
      )}
    </nav>
  )
}

<style>
  .pagination {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(31, 32, 35, 0.08);
  }

  .pagination-pages {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.45rem;
  }

  .pagination-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.5rem;
    min-height: 2.5rem;
    padding: 0.5rem 0.75rem;
    border: 1px solid rgba(31, 32, 35, 0.12);
    border-radius: var(--radius-card);
    background: rgba(255, 255, 255, 0.8);
    color: var(--color-charcoal);
    font-weight: 700;
  }

  .pagination-link:hover,
  .pagination-link.active {
    border-color: var(--color-crimson);
    background: var(--color-crimson);
    color: var(--color-white);
  }

  .pagination-step {
    min-width: 6.5rem;
  }

  .pagination-link.disabled {
    color: var(--color-grey-500);
    pointer-events: none;
    background: rgba(244, 245, 246, 0.8);
  }
</style>
